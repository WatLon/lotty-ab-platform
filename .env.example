# App
PORT=3000
NODE_ENV=development
APP_SECRET=replace-with-strong-secret

# Decide API throttling (for stress tests, set DECIDE_THROTTLE_DISABLED=1)
DECIDE_THROTTLE_DISABLED=0
DECIDE_THROTTLE_LIMIT=200
DECIDE_THROTTLE_TTL_MS=1000
AUTH_ACCESS_TOKEN_TTL_SECONDS=2592000
DECISION_TOKEN_TTL_SECONDS=604800
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=SecurePass123
BOOTSTRAP_ADMIN_NAME=Bootstrap Admin

# Subject Participation
SUBJECT_PARTICIPATION_MAX_CONCURRENT_EXPERIMENTS=3
SUBJECT_PARTICIPATION_COOLDOWN_AFTER_TOTAL=10
SUBJECT_PARTICIPATION_ROLLING_WINDOW_MS=86400000
SUBJECT_PARTICIPATION_COOLDOWN_PERIOD_MS=3600000

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
PG_POOL_MAX=20
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_POOL_CONNECTION_TIMEOUT_MS=5000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/app

# Redis
REDIS_URL=redis://localhost:6379

# Kafka transport
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=lotty-ab-platform
EXPERIMENT_PROJECTION_GROUP_ID=experiment-projection
NOTIFICATION_DISPATCH_GROUP_ID=notification-dispatch
DECISION_LOGS_GROUP_ID=decision-logs-writer
EVENTS_NORMALIZER_GROUP_ID=events-normalizer
EVENTS_ATTRIBUTION_GROUP_ID=events-attribution
CONTROL_EVENTS_GROUP_ID=runtime-compiler-control-events

# Service-specific runtime
# Use dedicated entrypoints:
# - bun src/apps/control-api/main.ts
# - bun src/apps/decide-api/main.ts
# - bun src/apps/ingest-api/main.ts
# - bun src/apps/control-workers/main.ts
# - bun src/apps/ingest-workers/main.ts
RUNTIME_SNAPSHOT_REDIS_STARTUP_TIMEOUT_MS=5000
EVENT_TYPE_CATALOG_REDIS_STARTUP_TIMEOUT_MS=5000

# ClickHouse
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_DATABASE=default
CLICKHOUSE_USER=lotty
CLICKHOUSE_PASSWORD=lotty
CLICKHOUSE_DECISIONS_KAFKA_GROUP=clickhouse-decisions-sink
CLICKHOUSE_DECISIONS_KAFKA_CONSUMERS=1

# Observability (optional for local dev)
OTEL_SERVICE_NAME=lotty-ab-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_REPORTS_BEARER_TOKEN=
