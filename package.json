{
  "name": "lotty-ab-platform",
  "version": "0.0.1",
  "description": "LOTTY A/B experimentation platform — feature flags, experiments, runtime decisions, event ingestion, reports, guardrails",
  "author": "Amir (watlon)",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "bunx nest build",
    "format": "bunx biome format --write src test",
    "start": "bunx nest start",
    "start:dev": "bunx nest start --watch",
    "start:debug": "bunx nest start --debug --watch",
    "start:control-api": "bun src/apps/control-api/main.ts",
    "start:decide-api": "bun src/apps/decide-api/main.ts",
    "start:ingest-api": "bun src/apps/ingest-api/main.ts",
    "start:control-workers": "bun src/apps/control-workers/main.ts",
    "start:ingest-workers": "bun src/apps/ingest-workers/main.ts",
    "start:prod": "bun dist/src/apps/control-api/main.js",
    "lint": "bunx biome check src",
    "lint:arch": "vitest run ./test/architecture/microservice-boundaries.spec.ts",
    "lint:all": "bun run lint:arch && bunx biome check src test",
    "test": "vitest run ./test/unit ./test/architecture",
    "test:unit": "vitest run ./test/unit",
    "test:integration": "docker compose -f docker-compose.dev.yml --profile test up -d postgres redis kafka kafka-init clickhouse clickhouse-bootstrap && docker compose -f docker-compose.dev.yml --profile test run --rm test-runner sh -lc \"bun install --frozen-lockfile && bun run --bun vitest run ./test/integration\"",
    "test:e2e": "docker compose -f docker-compose.dev.yml --profile test up -d postgres redis kafka kafka-init clickhouse clickhouse-bootstrap && docker compose -f docker-compose.dev.yml --profile test run --rm test-runner sh -lc \"bun install --frozen-lockfile && bun run --bun vitest run --maxWorkers=1 ./test/e2e\"",
    "test:cov": "vitest run --coverage ./test/unit ./test/architecture",
    "perf:smoke": "k6 run perf/k6/smoke-decide-ingest.js -e BASE_URL=${BASE_URL:-http://localhost:80}",
    "perf:decide:p99": "k6 run perf/k6/decide-p99-stress.js -e BASE_URL=${BASE_URL:-http://localhost:80}",
    "seed:demo": "bash scripts/seed-demo.sh",
    "typecheck": "bunx prisma generate && bunx tsc -p tsconfig.build.json --noEmit",
    "typecheck:all": "bunx prisma generate && bunx tsc -p tsconfig.json --noEmit",
    "openapi:lint": "sh scripts/openapi-lint.sh"
  },
  "dependencies": {
    "@clickhouse/client": "^1.17.0",
    "@fastify/static": "^8.3.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.13",
    "@nestjs/platform-fastify": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.5",
    "@nestjs/throttler": "^6.4.0",
    "@opentelemetry/auto-instrumentations-node": "^0.69.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/instrumentation-pino": "^0.57.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@scalar/nestjs-api-reference": "^1.0.23",
    "ajv": "^8.18.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.2.3",
    "ioredis": "^5.9.3",
    "kafkajs": "^2.2.4",
    "murmurhash3js-revisited": "^3.0.0",
    "nestjs-pino": "^4.5.0",
    "nestjs-zod": "^5.1.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.3.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bun": "^1.3.8",
    "@types/murmurhash3js-revisited": "^3.0.3",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.0.0",
    "typescript": "^5.7.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "trustedDependencies": [
    "@nestjs/core",
    "@prisma/engines",
    "@scarf/scarf",
    "prisma",
    "protobufjs",
    "unrs-resolver"
  ]
}
